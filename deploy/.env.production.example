# ===========================================================================
# SyntropyBridge - Production Environment Variables
# ===========================================================================
# Copy this file to .env.production and fill in every value marked <...>.
#
#   cp deploy/.env.production.example .env.production
#   chmod 600 .env.production   # restrict read access
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ===========================================================================

# ---------------------------------------------------------------------------
# Required: Application
# ---------------------------------------------------------------------------

# Environment mode. Must be "production" for production deployments.
# Enables strict validation, disables /docs, enforces CORS origins.
ENV=production

# JWT signing key. Generate a unique 48+ char random string.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=<generate-a-unique-random-string>

# Fernet encryption key for storing provider API keys at rest.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate-a-fernet-key>

# Allowed CORS origins (comma-separated). Must NOT be "*" in production.
CORS_ORIGINS=https://your-domain.com

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the SQLite database file.
# For Docker: /app/data/data.db (volume-mounted)
# For bare-metal: /var/lib/api-zhuanzhuan/data.db
DATABASE_PATH=/var/lib/api-zhuanzhuan/data.db

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------

# Maximum requests per IP per minute
RATE_LIMIT_PER_MINUTE=60

# Maximum requests per IP per hour
RATE_LIMIT_PER_HOUR=1000

# Trusted proxy IPs (comma-separated). Set to your Nginx/reverse proxy IP.
# Required for correct client IP detection behind a proxy.
TRUSTED_PROXIES=127.0.0.1

# ---------------------------------------------------------------------------
# Security & Auth
# ---------------------------------------------------------------------------

# Allow legacy X-API-Key header for authentication (default: true)
# ALLOW_LEGACY_X_API_KEY=true

# Allow API key login to obtain session cookies (default: true)
# ALLOW_API_KEY_LOGIN=true

# Content Security Policy strictness: 0=dev, 1=production, 2=strict
# CSP_LEVEL=1

# ---------------------------------------------------------------------------
# Channel Routing
# ---------------------------------------------------------------------------

# Seconds to wait before retrying a failed channel (default: 60)
# CHANNEL_COOLDOWN_SECONDS=60

# Maximum fallback channels to try before giving up (default: 1)
# CHANNEL_FALLBACK_MAX=1

# ---------------------------------------------------------------------------
# Provider API Keys
# ---------------------------------------------------------------------------
# At least one provider key is required for the proxy to function.
# Keys can also be configured via the admin UI (stored encrypted in DB).

# MiniMax
MINIMAX_API_KEY=<your-minimax-api-key>
# MINIMAX_API_BASE=https://api.minimaxi.com

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_BASE=https://api.anthropic.com

# Google
# GOOGLE_API_KEY=...
# GOOGLE_API_BASE=https://generativelanguage.googleapis.com

# NVIDIA
# NVIDIA_API_KEY=...
# NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# DeepSeek
# DEEPSEEK_API_KEY=...
# DEEPSEEK_API_BASE=https://api.deepseek.com

# Moonshot
# MOONSHOT_API_KEY=...
# MOONSHOT_API_BASE=https://api.moonshot.cn

# Zhipu (GLM)
# ZHIPU_API_KEY=...
# ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4

# Doubao (ByteDance)
# DOUBAO_API_KEY=...
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# Aliyun (DashScope)
# ALIYUN_API_KEY=...
# ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode

# OpenRouter
# OPENROUTER_API_KEY=...
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Payment (optional - Stripe)
# ---------------------------------------------------------------------------

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Email (optional - notifications, password reset)
# ---------------------------------------------------------------------------
# If not configured, emails are logged to audit_logs instead of sent.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=...
# SMTP_FROM=noreply@your-domain.com
# SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Admin Bootstrap (optional - for automated first-run setup)
# ---------------------------------------------------------------------------
# If set, the admin user is created automatically on first startup.
# Otherwise, use the admin init wizard in the web UI.

# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=<strong-password>

# ---------------------------------------------------------------------------
# Logging & Debug
# ---------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable Swagger docs at /docs (disable in production)
# DEBUG=false

# ---------------------------------------------------------------------------
# SSL (optional - only if terminating TLS at the app level)
# ---------------------------------------------------------------------------
# Normally TLS is terminated at Nginx. Only set these if you need
# the app to serve HTTPS directly.

# SSL_KEYFILE=/path/to/key.pem
# SSL_CERTFILE=/path/to/cert.pem
